# syntax=docker/dockerfile:1.7
# Eagle-RAG MCP HTTP service image (multi-stage, non-root runtime).
#
# Shares base image / Python version / uv install mode / non-root user (``eagle``,
# uid 1000) with ``docker/Dockerfile.api``. Only the ENTRYPOINT differs: standalone
# MCP streamable HTTP (``uvicorn eagle_rag.api.mcp_server_http:app``,
# stateless + JSON-only).
#
# Build: docker build -f docker/Dockerfile.mcp -t eagle-rag-mcp .
# Run:   docker run -p 8081:8081 -e AUTH_API_KEY=... eagle-rag-mcp
ARG PYTHON_VERSION=3.12

# ---------------- builder ----------------
FROM python:${PYTHON_VERSION}-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/opt/venv \
    # Force uv to use the base-image system Python (same as Dockerfile.api) so
    # runtime venv symlinks are not broken.
    UV_PYTHON_PREFERENCE=only-system

WORKDIR /app

# System deps aligned with Dockerfile.api (MCP tools call vision/render layers;
# need browser libs + CJK fonts) + git (pixelrag is a git+https dependency).
RUN apt-get update && apt-get install -y --no-install-recommends \
        libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libdrm2 libxkbcommon0 \
        libxcomposite1 libxdamage1 libxfixes3 libxrandr2 libgbm1 libasound2 \
        fonts-noto-cjk fonts-noto-color-emoji \
        curl git \
    && rm -rf /var/lib/apt/lists/*

# uv (pinned upstream image; not installed separately).
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Install deps first (layer cache): sync from lockfile without installing the project
# (source is copied later). pixelrag_render / pixelrag_embed are core dependencies.
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev --no-install-project

# ---------------- runtime ----------------
FROM python:${PYTHON_VERSION}-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/opt/venv/bin:${PATH}" \
    # fastmcp stateless mode: any replica can handle any request (no sticky routing).
    FASTMCP_STATELESS_HTTP=true \
    # Standalone MCP HTTP defaults (overridable at runtime).
    MCP_TRANSPORT=http \
    MCP_HOST=0.0.0.0 \
    MCP_PORT=8081 \
    MCP_WORKERS=4 \
    MCP_STANDALONE=true \
    MCP_AUTH_PROVIDER=static-token \
    # PluginAudit multi-sink defaults (JSONL + Redis recent via MCP_REDIS_URL / CELERY_BROKER_URL).
    TELEMETRY_ENABLED=true \
    AI_TELEMETRY_LOG_FILE=logs/ai_telemetry.jsonl \
    OP_LOG_FILE=logs/eagle_rag.log \
    PLUGIN_AUDIT_ENABLED=true \
    PLUGIN_AUDIT_REDIS_ENABLED=true

WORKDIR /app

# Runtime system libs (same as Dockerfile.api) + curl (healthcheck).
RUN apt-get update && apt-get install -y --no-install-recommends \
        libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libdrm2 libxkbcommon0 \
        libxcomposite1 libxdamage1 libxfixes3 libxrandr2 libgbm1 libasound2 \
        fonts-noto-cjk fonts-noto-color-emoji \
        curl \
    && rm -rf /var/lib/apt/lists/*

# Copy venv from builder.
COPY --from=builder /opt/venv /opt/venv

# Non-root user (same as Dockerfile.api): chown /app and writable dirs (logs / data)
# before USER. settings.yaml defaults put op/ai logs under logs/ and data_dir=./data
# relative to /app; root-owned /app causes PermissionError at startup.
RUN useradd --create-home --uid 1000 eagle \
    && mkdir -p /app/logs /app/data \
    && chown -R eagle:eagle /app

# Source and lockfiles (eagle_rag/settings.yaml ships in-package).
COPY --chown=eagle:eagle pyproject.toml uv.lock ./
COPY --chown=eagle:eagle eagle_rag ./eagle_rag
COPY --chown=eagle:eagle plugins ./plugins

USER eagle

EXPOSE 8081

# ENTRYPOINT: standalone MCP streamable HTTP service.
# - Shell form so ${MCP_WORKERS} expands at runtime (Swarm stack env / docker run -e).
# - ``eagle_rag.api.mcp_server_http:app`` is a module-level Starlette ASGI app;
#   uvicorn loads the import string and supports ``--workers`` prefork.
# - ``--host 0.0.0.0 --port 8081`` matches settings.mcp defaults.
ENTRYPOINT uvicorn eagle_rag.api.mcp_server_http:app \
    --host 0.0.0.0 --port 8081 --workers ${MCP_WORKERS}
