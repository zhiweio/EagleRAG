# Knowhere self-hosted default environment.
#
# This file is loaded by Docker Compose before `.env`.
# Do not put private deployment values in this file. To customize Knowhere,
# create a small `.env` file with only the values you need to override.
# Empty values mean the related optional feature is disabled.

# -----------------------------------------------------------------------------
# Public URL and compose-level options
# -----------------------------------------------------------------------------
DASHBOARD_PUBLIC_URL=http://localhost:13000
# Host ports are offset to avoid conflicts with eagle-rag main compose (postgres:5432 / redis:6379 / frontend:3000);
# eagle-rag reaches app only via knowhere-net DNS name knowhere:5005, not these host ports.
DASHBOARD_HOST_BIND=127.0.0.1
DASHBOARD_HOST_PORT=13000
API_HOST_BIND=127.0.0.1
API_HOST_PORT=5005
POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_HOST_PORT=15432
REDIS_HOST_BIND=127.0.0.1
REDIS_HOST_PORT=16379
LOCALSTACK_HOST_BIND=127.0.0.1
LOCALSTACK_HOST_PORT=4566
KNOWHERE_IMAGE=ghcr.io/ontos-ai/knowhere:latest

# -----------------------------------------------------------------------------
# Application runtime
# -----------------------------------------------------------------------------
ENVIRONMENT=production
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
APP_TITLE=Knowhere API
APP_DESCRIPTION=Document ingestion, retrieval, and MCP backend
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
API_STANDALONE_MODE_ENABLED=false
BILLING_ENABLED=false
RATE_LIMIT_ENABLED=false
PASSWORD_LOGIN_ENABLED=true
TMP_PATH=/tmp/knowhere
USERS_DATA_PATH=/data/users
FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
CHROMEDRIVER_PATH=/usr/bin/chromedriver
NODE_ENV=production
SELF_HOSTED_SECRETS_PATH=/data/secrets
SELF_HOSTED_WAIT_ATTEMPTS=60
SELF_HOSTED_WAIT_DELAY_SECONDS=2
SELF_HOSTED_INIT_POSTGRES_EXTENSIONS=true
# Generated automatically when unset. Uncomment only if you need to provide your own values.
# SECRET_KEY=
# BETTER_AUTH_SECRET=
# USERS_VERIFY_TOKEN_SECRET=
# USERS_RESET_PASSWORD_TOKEN_SECRET=

# -----------------------------------------------------------------------------
# Dashboard URLs and auth
# -----------------------------------------------------------------------------
DASHBOARD_PORT=3000
API_PORT=5005
NEXT_PUBLIC_API_URL=http://127.0.0.1:5005/api
NEXT_PUBLIC_AUTH_BASE_URL=/api/auth
# Derived from DASHBOARD_PUBLIC_URL when unset.
# NEXT_PUBLIC_APP_URL=
# BETTER_AUTH_URL=
# FRONTEND_URL=
INTERNAL_DASHBOARD_ENDPOINT=http://127.0.0.1:3000

# Optional OAuth providers.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Optional email provider for email links and password reset emails.
RESEND_API_KEY=
RESEND_FROM=onboarding@example.com
RESEND_FROM_EMAIL=noreply@example.com
RESEND_FROM_NAME=Knowhere
RESEND_MAX_RETRIES=3
RESEND_RETRY_DELAY=1.0
RESEND_TEMPLATE_WELCOME=
RESEND_TEMPLATE_PURCHASE_CONFIRMATION=
RESEND_TEMPLATE_JOB_COMPLETION=
RESEND_TEMPLATE_JOB_FAILURE=
RESEND_TEMPLATE_WELCOME_ENABLED=false
RESEND_TEMPLATE_PURCHASE_CONFIRMATION_ENABLED=false
RESEND_TEMPLATE_JOB_COMPLETION_ENABLED=false
RESEND_TEMPLATE_JOB_FAILURE_ENABLED=false

# Optional anonymous telemetry, analytics, and branding.
TELEMETRY_ENABLED=true
GA_MEASUREMENT_ID=
MOESIF_APPLICATION_ID=
LOGFIRE_TOKEN=
COMPANY_NAME=Knowhere AI
SIMPLE_COMPANY_NAME=Knowhere
ICP_NUMBER=
ICP_URL=https://beian.miit.gov.cn/
HTTPS_PROXY=
HTTP_PROXY=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=root123
DB_SSL_MODE=disable
UNSAFE_DB_SSL_ENABLED=true
# DB_SSL_MODE options: disable, allow, prefer, require, verify-ca, verify-full.
# DB_SSL_CERT=/path/to/client-cert.pem
# DB_SSL_KEY=/path/to/client-key.pem
# DB_SSL_ROOT_CERT=/path/to/ca-cert.pem
# Upstream API/dashboard examples use DATABASE_URL. Self-hosted keeps separate API
# and dashboard URLs, so use API_DATABASE_URL or DASHBOARD_DATABASE_URL instead.
# DATABASE_URL=
# Derived from the built-in database defaults when unset. Use these only for custom database URLs.
# API_DATABASE_URL=
# DASHBOARD_DATABASE_URL=

# -----------------------------------------------------------------------------
# Redis and Celery
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
BROKER_POOL_LIMIT=10
# Derived from REDIS_* when unset.
# CELERY_REDIS_URL=

# -----------------------------------------------------------------------------
# Local S3-compatible storage
# -----------------------------------------------------------------------------
S3_TYPE=s3
S3_BUCKET_NAME=knowhere-uploads
# Derived from S3_BUCKET_NAME when unset.
# S3_UPLOADS_BUCKET=
S3_RESULTS_BUCKET=knowhere-results
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_ENDPOINT_URL=http://localhost.localstack.cloud:4566
S3_PRIVATE_DOMAIN=http://localhost.localstack.cloud:4566
S3_TEMP_PATH=/tmp/knowhere
S3_REGION=us-west-1
S3_USE_SSL=false
S3_ADDRESSING_STYLE=path
S3_WEBHOOK_AUTH_TOKEN=change-me-storage-webhook-token
SNS_SIGNATURE_VERIFICATION=false
SELF_HOSTED_CREATE_STORAGE_BUCKETS=true
SELF_HOSTED_CONFIGURE_STORAGE_EVENTS=true
SELF_HOSTED_S3_EVENT_TOPIC_NAME=knowhere-s3-upload-events
SELF_HOSTED_S3_EVENT_WEBHOOK_URL=http://app:5005/v1/internal/s3-events
SELF_HOSTED_STORAGE_CORS_ALLOWED_ORIGINS=
# Derived from S3_ENDPOINT_URL when unset.
# SELF_HOSTED_AWS_ENDPOINT_URL=

# Optional Alibaba OSS callback settings.
OSS_ENDPOINT=
OSS_EVENT_CALLBACK_KEY=
OSS_EVENT_VERIFY_SIGNATURE=true

# -----------------------------------------------------------------------------
# AI providers and model choices
# -----------------------------------------------------------------------------
DS_KEY=
DS_URL=https://api.deepseek.com/v1
GPT_API_KEY=
GLM_API_KEY=
GLM_URL=https://open.bigmodel.cn/api/paas/v4
ALI_API_KEYS=
ALI_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALI_TOKEN_RPM_LIMIT=300
ALI_TOKEN_DAILY_LIMIT=10000
ALI_TOKEN_COOLDOWN_SECONDS=60
ALI_INLINE_MAX_RETRIES=3
ALI_SDK_MAX_RETRIES=3
ARK_API_KEY=
ARK_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
EMBEDDING_MODEL=text-embedding-v4
NORMOL_MODEL=deepseek-v4-flash
HIERARCHY_LLM_MODEL=deepseek-v4-flash
IMAGE_MODEL=qwen3.6-flash
IMAGE_MODEL_MAX=qwen3.6-flash

# -----------------------------------------------------------------------------
# File handling and retrieval defaults
# -----------------------------------------------------------------------------
SUPPORTED_EXTENSIONS=.doc,.docx,.pdf,.txt,.xls,.xlsx,.csv,.pptx,.jpg,.jpeg,.png,.md
MAX_FILE_SIZE=104857600
MAX_IMAGE_SIZE=10485760
PDF_PROFILE_TOC_ENABLED=false
MIN_CONFIDENCE_THRESHOLD=0.05
HIGH_IOU_THRESHOLD=0.9
DEFAULT_EMBEDDING_DIM=1024
DEFAULT_TOP_K=5
DEFAULT_BATCH_SIZE=32
DEFAULT_EPOCHS=3
DEFAULT_THRESHOLD=0.5

# -----------------------------------------------------------------------------
# Webhooks and async callbacks
# -----------------------------------------------------------------------------
WEBHOOK_SIGNING_SECRET=
WEBHOOK_MASTER_KEY=
QSTASH_TOKEN=
QSTASH_CALLBACK_BASE_URL=http://127.0.0.1:5005/api/v1
QSTASH_MAX_RETRIES=5
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# -----------------------------------------------------------------------------
# Billing and credits. Self-hosted defaults keep billing disabled.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
FREE_PLAN_INITIAL_CREDITS=5

# -----------------------------------------------------------------------------
# Optional parsing providers
# -----------------------------------------------------------------------------
MINERU_API_KEYS=
MINERU_URL=https://mineru.net/api/v4
MINERU_UPLOAD_MODE_ENABLED=true
MINERU_TOKEN_RPM_LIMIT=300
MINERU_TOKEN_DAILY_LIMIT=10000
MINERU_TOKEN_COOLDOWN_SECONDS=60
ILOVEAPI_PUBLIC_KEY=
ILOVEAPI_SECRET_KEY=
ILOVEAPI_BASE_URL=https://api.ilovepdf.com/v1
ILOVEAPI_TIMEOUT=120

# -----------------------------------------------------------------------------
# Compatibility fields kept for retained legacy code paths
# -----------------------------------------------------------------------------
ALL_DF_COLS=content,path,type,length,keywords,summary,know_id,tokens,connectto,addtime,page_nums
DEFAULT_FOLDERS=Supplementary_Files,Temporary_Files,templates,images,fragments
KB_TERM=KB_DATA
KB_VEC_TERM=KB_VECS
META_PATH=app/core/config/Meta_setting.csv
CONFIG_PATH=app/core/config/config.txt
PATH_IMAGE_PATTERN=.*\.(png|jpe?g|gif)$
IMG_TBL_PATTERN=\[(?:images|tables)/[^\]]+\]
SPLIT_CHAR=/


# -----------------------------------------------------------------------------
# Retrieval and agentic mode
# -----------------------------------------------------------------------------
# Agentic retrieval uses LLM-driven hierarchical navigation for higher-quality
# results. Set to false to fall back to the legacy 3-channel RRF baseline.
RETRIEVAL_AGENTIC_ENABLED=true
RETRIEVAL_PLANNER_MODEL=
RETRIEVAL_PLANNER_THINKING_BUDGET=4000
RETRIEVAL_DECOMPOSITION_MAX_STEPS=5
RETRIEVAL_WALLET_TOTAL_BUDGET=200000
RETRIEVAL_WALLET_PER_RETRIEVE_STEP_BUDGET=40000
RETRIEVAL_WALLET_PER_SYNTHESIZE_STEP_BUDGET=6000
RETRIEVAL_WORKFLOW_PARALLEL_MAX=3