# Knowhere self-hosted stack environment variable example (independent of eagle-rag).
#
# Usage: cd docker/knowhere-self-hosted && cp .env.example .env, then fill in real secrets.
# Precedence: env.defaults (vendor defaults, do not edit) < this .env (user overrides).
# Full variable list in env.defaults; only common overrides listed here.

# ---------- Image ----------
KNOWHERE_IMAGE=ghcr.io/ontos-ai/knowhere:latest   # China: switch to Aliyun mirror registry

# ---------- Port bindings (offset to avoid eagle-rag; expose to host for dev, keep 127.0.0.1 in prod) ----------
# Defaults in env.defaults: dashboard 13000 / api 5005 / postgres 15432 / redis 16379 / localstack 4566
DASHBOARD_HOST_BIND=0.0.0.0
DASHBOARD_HOST_PORT=13000
API_HOST_BIND=0.0.0.0
API_HOST_PORT=5005
# POSTGRES_HOST_PORT=15432
# REDIS_HOST_PORT=16379

# ---------- Database password ----------
POSTGRES_PASSWORD=root123          # Production: use strong password (matches env.defaults default; override to harden)

# ---------- LLM keys (DeepSeek or DashScope; required for PDF/Excel parsing) ----------
DS_KEY=                            # DeepSeek API key
ALI_API_KEYS=                      # DashScope API key (comma-separated for key rotation)
# Model selection (env.defaults default deepseek-v4-flash; use qwen-plus with DashScope)
# NORMOL_MODEL=qwen-plus
# HIERARCHY_LLM_MODEL=qwen-plus
# IMAGE_MODEL=qwen3.6-flash

# ---------- PDF first-time parsing (MinerU) required ----------
MINERU_API_KEYS=                   # mineru.net API key (comma-separated for key rotation)

# ---------- Telemetry (recommended off for self-hosted) ----------
TELEMETRY_ENABLED=false
DASHBOARD_PUBLIC_URL=http://localhost:3000
