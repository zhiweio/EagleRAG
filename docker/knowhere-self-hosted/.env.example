# Knowhere 自托管栈环境变量示例（独立于 eagle-rag）。
#
# 用法：cd docker/knowhere-self-hosted && cp .env.example .env，再填入真实密钥。
# 优先级：env.defaults（vendor 默认，勿改） < 本 .env（用户覆盖）。
# 完整变量列表见 env.defaults；此处仅列出常用覆盖项。

# ---------- 镜像 ----------
KNOWHERE_IMAGE=ghcr.io/ontos-ai/knowhere:latest   # 国内可改阿里云镜像仓库

# ---------- 端口绑定（已偏移避开 eagle-rag；dev 调试暴露到宿主，prod 可保持 127.0.0.1） ----------
# 默认值见 env.defaults：dashboard 13000 / api 5005 / postgres 15432 / redis 16379 / localstack 4566
DASHBOARD_HOST_BIND=0.0.0.0
DASHBOARD_HOST_PORT=13000
API_HOST_BIND=0.0.0.0
API_HOST_PORT=5005
# POSTGRES_HOST_PORT=15432
# REDIS_HOST_PORT=16379

# ---------- 数据库口令 ----------
POSTGRES_PASSWORD=root123          # 生产请改强密码（与 env.defaults 默认一致，覆盖以加固）

# ---------- LLM 密钥（DeepSeek 与 DashScope 二选一，PDF/Excel 解析必需） ----------
DS_KEY=                            # DeepSeek API key
ALI_API_KEYS=                      # DashScope API key（逗号分隔多 key 轮询）
# 模型选择（env.defaults 默认 deepseek-v4-flash，用 DashScope 时改 qwen-plus）
# NORMOL_MODEL=qwen-plus
# HIERARCHY_LLM_MODEL=qwen-plus
# IMAGE_MODEL=qwen3.6-flash

# ---------- PDF 首次解析（MinerU）必需 ----------
MINERU_API_KEYS=                   # mineru.net API key（逗号分隔多 key 轮询）

# ---------- 遥测（自托管建议关闭） ----------
TELEMETRY_ENABLED=false
DASHBOARD_PUBLIC_URL=http://localhost:3000
