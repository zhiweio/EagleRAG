# syntax=docker/dockerfile:1.7
# Eagle-RAG Celery Worker image (multi-stage, non-root runtime).
# Shares system deps and venv with API; adds Chromium for pixelrag queue rendering.
# QUEUES / CONCURRENCY are injected by docker-compose per service.
# Build: docker build -f docker/Dockerfile.worker -t eagle-rag-worker .
ARG PYTHON_VERSION=3.12
ARG MODEL_REPO_ID=Qwen/Qwen3-VL-Embedding-2B
ARG MODEL_DOWNLOAD_SOURCE=modelscope
ARG MODEL_LOCAL_PATH=/opt/huggingface/model
ARG HF_ENDPOINT=https://hf-mirror.com
ARG HF_HUB_DOWNLOAD_MAX_WORKERS=8

# ---------------- model prefetch (isolated from app code / Playwright layers) ----------------
FROM python:${PYTHON_VERSION}-slim AS model-prefetch

ARG MODEL_REPO_ID
ARG MODEL_DOWNLOAD_SOURCE
ARG MODEL_LOCAL_PATH
ARG HF_ENDPOINT
ARG HF_HUB_DOWNLOAD_MAX_WORKERS

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HF_HOME=/opt/huggingface/hub \
    HF_ENDPOINT=${HF_ENDPOINT} \
    HF_HUB_DOWNLOAD_TIMEOUT=600 \
    HF_HUB_DOWNLOAD_MAX_WORKERS=${HF_HUB_DOWNLOAD_MAX_WORKERS} \
    MODEL_REPO_ID=${MODEL_REPO_ID} \
    MODEL_DOWNLOAD_SOURCE=${MODEL_DOWNLOAD_SOURCE} \
    MODEL_LOCAL_PATH=${MODEL_LOCAL_PATH} \
    MODEL_CACHE_DIR=/var/cache/eagle-rag/visual-model

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/
RUN uv venv /opt/venv \
    && uv pip install --python /opt/venv/bin/python 'huggingface_hub>=0.26' 'modelscope>=1.9'

COPY docker/scripts/prefetch_hf_model.py /tmp/prefetch_hf_model.py
RUN --mount=type=cache,target=/var/cache/eagle-rag/visual-model,id=eagle-rag-visual-model-cache \
    mkdir -p /opt/huggingface \
    && /opt/venv/bin/python /tmp/prefetch_hf_model.py \
    && rm /tmp/prefetch_hf_model.py

# ---------------- biomed encoder prefetch (optional, biomed profile only) ----------------
# Downloads PubMedBERT / MolFormer / MedImageInsight / UNI2 weights so runtime
# never depends on HuggingFace connectivity. Enabled via PREFETCH_BIOMED_MODELS=1.
FROM model-prefetch AS biomed-model-prefetch

ARG PREFETCH_BIOMED_MODELS=0
ARG BIOMED_HTTP_PROXY=
ENV BIOMED_HTTP_PROXY=${BIOMED_HTTP_PROXY}

COPY docker/scripts/prefetch_biomed_models.py /tmp/prefetch_biomed_models.py
RUN --mount=type=cache,target=/var/cache/eagle-rag/biomed-models,id=eagle-rag-biomed-models-cache \
    mkdir -p /opt/huggingface/biomed \
    && if [ "${PREFETCH_BIOMED_MODELS}" = "1" ]; then \
        PREFETCH_BIOMED_MODELS=1 \
        BIOMED_MODEL_ROOT=/opt/huggingface/biomed \
        /opt/venv/bin/python /tmp/prefetch_biomed_models.py; \
    else \
        echo "PREFETCH_BIOMED_MODELS=${PREFETCH_BIOMED_MODELS}; skipping biomed encoder prefetch"; \
    fi \
    && rm -f /tmp/prefetch_biomed_models.py

# ---------------- builder ----------------
FROM python:${PYTHON_VERSION}-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/opt/venv \
    PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers \
    # Force uv to use the base image system Python (/usr/local/bin/python3.12);
    # otherwise uv may fetch cpython elsewhere and runtime COPY of /opt/venv breaks symlinks.
    UV_PYTHON_PREFERENCE=only-system

WORKDIR /app

# System deps: Playwright libs, fonts, curl, git, JRE (tabula-py / knowhere-parse-sdk).
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libdrm2 libxkbcommon0 \
        libxcomposite1 libxdamage1 libxfixes3 libxrandr2 libgbm1 libasound2 \
        libcups2 libxshmfence1 libpangocairo-1.0-0 libpango-1.0-0 libcairo2 \
        fonts-noto-cjk fonts-noto-color-emoji \
        curl git default-jre-headless \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

ARG GITHUB_PROXY=
ENV UV_HTTP_TIMEOUT=600

COPY docker/scripts/uv_sync_with_retry.sh /tmp/uv_sync_with_retry.sh
COPY pyproject.toml uv.lock ./
RUN chmod +x /tmp/uv_sync_with_retry.sh \
    && GITHUB_PROXY="${GITHUB_PROXY}" /tmp/uv_sync_with_retry.sh \
    && rm /tmp/uv_sync_with_retry.sh

# Pre-fetch knowhere-parse-sdk worker cache (avoids runtime git clone on first parse).
ENV HOME=/root
RUN mkdir -p /root/.cache/knowhere-parse-sdk \
    && (/opt/venv/bin/python -c "from knowhere_parse import KnowhereParser; KnowhereParser()" || true)

# pixelrag queue needs Chromium (system libs installed above).
RUN /opt/venv/bin/playwright install chromium \
    && ln -sf /opt/pw-browsers/chromium-*/chrome-linux/chrome /usr/local/bin/chrome

# ---------------- runtime ----------------
FROM python:${PYTHON_VERSION}-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/opt/venv/bin:${PATH}" \
    PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers \
    HF_HOME=/opt/huggingface \
    VISUAL_EMBEDDING_MODEL=/opt/huggingface/model \
    QUEUES=router_queue \
    CONCURRENCY=4 \
    # PluginAudit multi-sink defaults (override via compose / .env).
    # Cross-process recent window requires CELERY_BROKER_URL → redis service.
    TELEMETRY_ENABLED=true \
    AI_TELEMETRY_LOG_FILE=logs/ai_telemetry.jsonl \
    OP_LOG_FILE=logs/eagle_rag.log \
    PLUGIN_AUDIT_ENABLED=true \
    PLUGIN_AUDIT_REDIS_ENABLED=true

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
        libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libdrm2 libxkbcommon0 \
        libxcomposite1 libxdamage1 libxfixes3 libxrandr2 libgbm1 libasound2 \
        libcups2 libxshmfence1 libpangocairo-1.0-0 libpango-1.0-0 libcairo2 \
        fonts-noto-cjk fonts-noto-color-emoji \
        curl git default-jre-headless \
    && rm -rf /var/lib/apt/lists/*

# venv + Playwright browsers + knowhere-parse-sdk worker cache + HuggingFace model weights.
# biomed-model-prefetch extends model-prefetch, so /opt/huggingface carries both the
# visual embedding model and (when PREFETCH_BIOMED_MODELS=1) biomed encoder weights.
COPY --from=builder /opt/venv /opt/venv
COPY --from=builder /opt/pw-browsers /opt/pw-browsers
COPY --from=builder /root/.cache/knowhere-parse-sdk /home/eagle/.cache/knowhere-parse-sdk
COPY --from=biomed-model-prefetch /opt/huggingface /opt/huggingface

# Stable symlink for pixelrag_render CHROME_PATH (survives Playwright version bumps).
RUN ln -sf /opt/pw-browsers/chromium-*/chrome-linux/chrome /usr/local/bin/chrome

# /app/logs holds PluginAudit AI JSONL + ops log; compose mounts ./logs:/app/logs.
RUN useradd --create-home --uid 1000 eagle \
    && mkdir -p /app/logs /app/data /home/eagle/.cache/knowhere-parse-sdk \
    && chown -R eagle:eagle /app /home/eagle/.cache /opt/huggingface

COPY --chown=eagle:eagle pyproject.toml uv.lock ./
COPY --chown=eagle:eagle eagle_rag ./eagle_rag
COPY --chown=eagle:eagle plugins ./plugins

USER eagle

CMD ["sh", "-c", "celery -A eagle_rag.tasks.celery_app worker -Q ${QUEUES} -c ${CONCURRENCY} --loglevel=info"]
