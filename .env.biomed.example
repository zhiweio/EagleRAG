# Biomed / HUTCHMED profile env template.
# Usage: cp .env.biomed.example .env.biomed  OR  task biomed:env
# Does not replace .env (core). See eval/biomed/SETUP.md.

# Eagle-RAG environment variable template.
# Usage: cp .env.example .env, then replace sensitive values marked below.
# Names align with ${VAR:-default} placeholders in eagle_rag/settings.yaml
# and environment blocks in docker-compose.yml.

# ---------- Application ----------
APP_ENV=dev                      # Runtime: dev | test | prod
APP_HOST=0.0.0.0                  # API bind address (use 0.0.0.0 in containers)
APP_PORT=8000                    # API listen port
LOG_LEVEL=INFO                   # Log level: DEBUG | INFO | WARNING | ERROR

# ---------- Knowledge base (multi-tenant) ----------
KB_NAME=hutchmed                 # HUTCHMED Oncology R&D knowledge base

# ---------- Plugin instance binding ----------
# EAGLE_RAG_PROFILE merges settings.yaml profiles: (core | biomed | lakehouse-bi).
# PLUGIN_NAMESPACE overrides plugins.default_namespace (= Milvus DB / PG filter).
EAGLE_RAG_PROFILE=biomed
# PLUGIN_NAMESPACE is set by profile overlay (biomed)
# PLUGIN_NAMESPACE=biomed

# ---------- Knowhere (document parsing: api | parser) ----------
# mode=api  — knowhere-python-sdk → self-hosted HTTP :5005 (docker/knowhere-self-hosted/).
# mode=parser — knowhere-parse-sdk in-process; no :5005 service; needs MinerU + LLM (see below).
KNOWHERE_MODE=api                # api | parser

# --- API mode (KNOWHERE_MODE=api) ---
# In Docker: reach via shared network knowhere-net at http://knowhere:5005 (default).
# Local dev (no Docker): use http://localhost:5005.
KNOWHERE_BASE_URL=http://knowhere:5005

# Knowhere API key: create in the self-hosted dashboard (optional for local standalone).
KNOWHERE_API_KEY=

# SDK client timeouts (seconds): poll interval / poll timeout / upload timeout / max retries
KNOWHERE_TIMEOUT=60
KNOWHERE_UPLOAD_TIMEOUT=600
KNOWHERE_POLL_INTERVAL=10
KNOWHERE_POLL_TIMEOUT=1800
KNOWHERE_MAX_RETRIES=5

# Parsing options forwarded to both backends (API ParsingParams / parser ParseOptions)
KNOWHERE_PARSING_MODEL=advanced

# --- Parser mode (KNOWHERE_MODE=parser) ---
# MinerU is required for PDF; LLM/VLM credentials reuse LLM_* / VLM_* above unless overridden in settings.
MINERU_API_KEYS=                 # mineru.net API key (comma-separated for key rotation)
MINERU_URL=https://mineru.net/api/v4
KNOWHERE_PARSER_TMP_PATH=        # empty → {STORAGE_DATA_DIR}/knowhere-parse
LLM_MOCK_ENABLED=false           # true short-circuits LLM calls (testing only)

# ---------- LLM (text model / routing, DeepSeek) ----------
LLM_API_KEY=                     # Replace with your API key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=deepseek-v4-pro          # DeepSeek-V4-Pro

# ---------- VLM (vision model for chart reading, DashScope Qwen-VL) ----------
VLM_API_KEY=                     # Replace with your DashScope API key
VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_MODEL=qwen-vl-max

# ---------- DashScope (shared by text embedding + rerank) ----------
DASHSCOPE_API_KEY=               # Replace with your API key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TEXT_EMBEDDING_MODEL=text-embedding-v4       # dim 1536
RERANK_TEXT_MODEL=qwen3-rerank

# ---------- Visual embedding (DashScope required for biomed e2e) ----------
# Do NOT use pixelrag local Qwen3-VL-Embedding-2B for this profile.
# Ingest + query must use the same provider; switching requires rebuilding eagle_visual.
VISUAL_EMBEDDING_PROVIDER=dashscope
VISUAL_EMBEDDING_MODEL=qwen3-vl-embedding
VISUAL_EMBEDDING_BATCH_SIZE=10                     # DashScope image batch size (≤10)
# VISUAL_EMBEDDING_TIMEOUT_S=60
# VISUAL_EMBEDDING_MAX_RETRIES=3
# DASHSCOPE_API_BASE=                               # optional native API base (workspace/region)
# Docker build: MODEL_DOWNLOAD_SOURCE=modelscope (default) | huggingface | auto
# Skip model-prefetch / HF bake when using dashscope (render still needs pixelrag_render).
MODEL_DOWNLOAD_SOURCE=modelscope
# HuggingFace mirror when MODEL_DOWNLOAD_SOURCE=huggingface or auto fallback
HF_ENDPOINT=https://hf-mirror.com
# Optional GitHub HTTPS mirror for docker build (git deps: knowhere-parse-sdk, PixelRAG).
# Example (China): GITHUB_PROXY=https://ghfast.top/
GITHUB_PROXY=
# Docker worker image bakes weights to /opt/huggingface/model when provider=pixelrag.
# Local dev: optional HF_HOME=./data/huggingface to persist Hub cache across runs.

# ---------- Milvus (vector store, dual collection) ----------
MILVUS_HOST=milvus               # Compose service name; use localhost when running locally
MILVUS_PORT=19530
MILVUS_VISUAL_INDEX_TYPE=hnsw    # hnsw | diskann (diskann for very large tile corpora)

# ---------- Redis / Celery ----------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0       # Celery broker (same DB as REDIS_URL)
CELERY_RESULT_BACKEND=redis://redis:6379/1   # Celery result backend (separate DB)

# ---------- MinIO (object storage) ----------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin       # Replace with a strong key
MINIO_SECRET_KEY=minioadmin       # Replace with a strong secret
MINIO_SECURE=false
MINIO_BUCKET=eagle-rag

# ---------- PostgreSQL (sessions / dedup / audit) ----------
POSTGRES_USER=eagle               # Replace in production
POSTGRES_PASSWORD=eagle           # Replace with a strong password
POSTGRES_DB=eagle_rag
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DSN=postgresql://eagle:eagle@postgres:5432/eagle_rag   # Must match USER/PASSWORD/DB above

# ---------- Storage / rendering ----------
STORAGE_DATA_DIR=/app/data
IMAGE_STORE=/app/data/images
PIXELRAG_BACKEND=cdp              # cdp | playwright (PixelRAG render_url backend)

# ---------- Router ----------
ROUTER_MODE=auto                   # auto | text | visual | hybrid

# ---------- Ingest limits (early reject before MinerU; Precision Extract caps) ----------
INGEST_LIMITS_ENABLED=true         # false disables size/page guards
INGEST_MAX_FILE_BYTES=209715200    # 200 MiB (MinerU Precision max file size)
INGEST_MAX_PDF_PAGES=200           # MinerU Precision max pages per PDF

# ---------- Frontend (Next.js, build-time) ----------
NEXT_PUBLIC_API_BASE=http://localhost:8000  # Browser-facing backend API URL

# ---------- Telemetry & tracing ----------
TELEMETRY_ENABLED=true                              # Master switch; false = minimal stdlib logging
OTEL_SERVICE_NAME=eagle-rag                         # OTel resource service.name
OTEL_TRACING_ENABLED=false                          # OTel tracing; set OTLP endpoint when true
OTEL_EXPORTER_OTLP_ENDPOINT=                        # OTLP collector, e.g. http://collector:4317
OTEL_EXPORTER_OTLP_INSECURE=true                    # true when collector has no TLS (plain gRPC)
AI_TELEMETRY_LOG_FILE=logs/ai_telemetry.jsonl       # AI events JSONL path
AI_TELEMETRY_LOG_LEVEL=INFO                         # AI events log level
OP_LOG_FILE=logs/eagle_rag.log                      # Operations log path
OP_LOG_LEVEL=INFO                                   # Operations log level
REDIS_LOG_CHANNEL=logs                              # Redis pub/sub channel for /admin/logs SSE
# PluginAudit (classification/routing decisions → JSONL + Redis recent + /health/plugins)
PLUGIN_AUDIT_ENABLED=true
PLUGIN_AUDIT_REDIS_ENABLED=true


# ---------- Biomed plugin (EAGLE_RAG_PROFILE=biomed) ----------
# Native domain encoders (PubMedBERT / ChemBERTa / BiomedCLIP). Requires: uv sync --extra biomed
# Production: pre-download weights at Docker build time (PREFETCH_BIOMED_MODELS=1) and leave
# EAGLE_BIOMED_ALLOW_DETERMINISTIC unset so missing weights fail-fast instead of silently
# degrading to hash embeddings. CI/test without native weights: set both to deterministic + 1.
EAGLE_BIOMED_ENCODER_MODE=auto
# EAGLE_BIOMED_ALLOW_DETERMINISTIC=1   # CI/test only; never enable in production
# Pre-downloaded model paths (populated by docker build with PREFETCH_BIOMED_MODELS=1):
# EAGLE_BIOMED_PUBMEDBERT_MODEL=/opt/huggingface/biomed/pubmedbert
# EAGLE_BIOMED_MOLFORMER_MODEL=/opt/huggingface/biomed/molformer
# EAGLE_BIOMED_MEDIMAGE_MODEL=/opt/huggingface/biomed/medimageinsight
# EAGLE_BIOMED_UNI2_MODEL=/opt/huggingface/biomed/uni2
# EAGLE_BIOMED_MEDCPT_RERANK_MODEL=/opt/huggingface/biomed/medcpt-rerank
# PLUGIN_NAMESPACE=biomed  # also set by docker-compose.biomed.yml / apply_biomed_env.py
# Optional: EAGLE_BIOMED_UMLS_MRCONSO_PATH=/path/to/MRCONSO.RRF
# Eval corpus + docs: see eval/biomed/
#
# Corpus download proxy (mainland China -> overseas PMC/PubChem/FDA). Used by
# eval/biomed/corpus/download_corpus.py; also accept --local-proxy / --proxy.
# BIOMED_HTTP_PROXY=http://127.0.0.1:1087
# BIOMED_SSL_INSECURE=1   # if proxy HTTPS MITM breaks certificate verification
